##############################################
# APPLICATION
##############################################

NODE_ENV=development

HOST=0.0.0.0

PORT=4000

APP_NAME=SmartPOS Platform

APP_URL=http://localhost:4000

##############################################
# DATABASE
##############################################

DATABASE_URL="postgresql://postgres:password@localhost:5432/smartpos"

##############################################
# JWT
##############################################

JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

JWT_EXPIRES_IN=15m

JWT_REFRESH_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_REFRESH_SECRET

JWT_REFRESH_EXPIRES_IN=30d

##############################################
# REDIS
##############################################

REDIS_HOST=localhost

REDIS_PORT=6379

REDIS_PASSWORD=

##############################################
# ENCRYPTION
##############################################

ENCRYPTION_KEY=CHANGE_ME_TO_A_32_BYTE_KEY

##############################################
# BLOCKCHAIN
##############################################

ETHEREUM_RPC=

POLYGON_RPC=

BSC_RPC=

TRON_RPC=

SOLANA_RPC=

##############################################
# WALLET
##############################################

MASTER_WALLET=

MASTER_PRIVATE_KEY=

##############################################
# PAYMENT PROVIDERS
##############################################

STRIPE_SECRET_KEY=

PAYSTACK_SECRET_KEY=

FLUTTERWAVE_SECRET_KEY=

##############################################
# EMAIL
##############################################

SMTP_HOST=

SMTP_PORT=

SMTP_USER=

SMTP_PASSWORD=

SMTP_FROM=

##############################################
# STORAGE
##############################################

AWS_ACCESS_KEY=

AWS_SECRET_KEY=

AWS_REGION=

AWS_BUCKET=

##############################################
# LOGGING
##############################################

LOG_LEVEL=info
