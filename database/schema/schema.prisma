generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================
// ENUMS
// ================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum MerchantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  DECOMMISSIONED
}

enum PaymentSessionStatus {
  PENDING
  PROCESSING
  AUTHORIZED
  CAPTURED
  FAILED
  CANCELLED
  TIMEOUT
}

enum PaymentEventStatus {
  CREATED
  GATEWAY_REQUEST
  GATEWAY_RESPONSE
  AUTHORIZED
  DECLINED
  CAPTURED
  FAILED
  TIMEOUT
}

enum TransactionStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  SETTLED
  FAILED
  REFUNDED
  VOIDED
}

enum TransactionEventStatus {
  CREATED
  AUTHORIZED
  SETTLEMENT_STARTED
  SETTLEMENT_COMPLETED
  RECEIPT_PRINTED
  FAILED
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum PrintStatus {
  PENDING
  PRINTED
  FAILED
}

enum WalletTransactionType {
  CREDIT
  DEBIT
}

enum WalletTransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum Blockchain {
  ERC20
  TRC20
  BEP20
}

enum Currency {
  USD
  KWD
  USDT
  USDC
}

enum GatewayProviderName {
  TRANSFI
  NEXAPAY
  PAYCLY
  BVNK
}

enum GatewayTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum GatewayCredentialStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  REVOKED
}

enum NotificationType {
  EMAIL
  IN_APP
  PUSH
}

enum ReportType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum LogLevel {
  INFO
  WARN
  ERROR
  DEBUG
}

enum SoftwareUpdateStatus {
  DRAFT
  PUBLISHED
  DEPRECATED
}

enum DeviceUpdateStatus {
  PENDING
  DOWNLOADING
  INSTALLING
  SUCCESS
  FAILED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum DeviceCommandType {
  RESTART
  SHUTDOWN
  DISABLE
  ENABLE
  PRINT_TEST
  UPDATE
  SYNC
  REFRESH
  LOCK
}

enum DeviceCommandStatus {
  PENDING
  SENT
  EXECUTED
  FAILED
  EXPIRED
}

// ================================
// MODELS
// ================================

model User {
  id               String          @id @default(uuid())
  email            String          @unique
  passwordHash     String
  firstName        String
  lastName         String
  status           UserStatus      @default(ACTIVE)
  lastLoginAt      DateTime?
  refreshTokenHash String?

  roleId           String?
  role             Role?            @relation(fields: [roleId], references: [id], onDelete: SetNull)
  merchantId       String?
  merchant         Merchant?        @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  transactions     Transaction[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  deviceSessions   DeviceSession[]
  paymentSessions  PaymentSession[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  @@index([email])
  @@index([merchantId])
  @@index([roleId])
  @@index([status])
  @@index([deletedAt])
}

model Role {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  isSystem    Boolean        @default(false)

  users       User[]
  permissions RolePermission[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([name])
}

model Permission {
  id          String         @id @default(uuid())
  name        String         @unique
  description String?
  resource    String
  action      String

  roles       RolePermission[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([name])
  @@index([resource, action])
}

model RolePermission {
  id           String       @id @default(uuid())
  roleId       String
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model Merchant {
  id                      String               @id @default(uuid())
  name                    String
  businessType            String
  email                   String               @unique
  phone                   String?
  address                 String?
  walletAddress           String?
  settlementCurrency      Currency             @default(USDT)
  timezone                String               @default("UTC")
  status                  MerchantStatus       @default(PENDING_VERIFICATION)

  users                   User[]
  devices                 PosDevice[]
  transactions            Transaction[]
  wallets                 Wallet[]
  receiptTemplates        ReceiptTemplate[]
  gatewayTransactions     GatewayTransaction[]
  settlements             SettlementRecord[]
  reports                 Report[]
  auditLogs               AuditLog[]
  apiKeys                 ApiKey[]
  merchantSettings        MerchantSettings?
  merchantBrand           MerchantBrand?
  terminalConfigs         TerminalConfiguration[]
  paymentSessions         PaymentSession[]
  gatewayCredentials      GatewayCredential[]
  exchangeRates           ExchangeRate[]

  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  deletedAt               DateTime?

  @@index([email])
  @@index([status])
  @@index([deletedAt])
}

model MerchantSettings {
  id                     String     @id @default(uuid())
  merchantId             String     @unique
  merchant               Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  receiptFooter          String?
  receiptLogoUrl         String?
  autoSettlementEnabled  Boolean    @default(true)
  settlementThreshold    Decimal?   @db.Decimal(12, 2)
  defaultGatewayProviderId String?
  defaultGateway         GatewayProvider? @relation(fields: [defaultGatewayProviderId], references: [id], onDelete: SetNull)

  displayProtocolName    String     @default("ONLINE 101.1")
  notificationPreferences Json?

  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
}

model MerchantBrand {
  id               String     @id @default(uuid())
  merchantId       String     @unique
  merchant         Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  companyName      String?
  logo             String?
  receiptLogo      String?
  supportPhone     String?
  supportEmail     String?
  primaryColor     String?
  secondaryColor   String?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model PosDevice {
  id                 String           @id @default(uuid())
  merchantId         String
  merchant           Merchant         @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deviceSerial       String           @unique
  name               String?
  model              String           @default("SUNMI V2s")
  status             DeviceStatus     @default(OFFLINE)
  appVersion         String?
  firmwareVersion    String?
  lastPingAt         DateTime?
  lastTransactionAt  DateTime?
  ipAddress          String?

  deviceSessions     DeviceSession[]
  transactions       Transaction[]
  terminalLogs       TerminalLog[]
  deviceUpdates      DeviceUpdate[]
  terminalConfig     TerminalConfiguration?
  deviceCommands     DeviceCommand[]

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  deletedAt          DateTime?

  @@index([merchantId])
  @@index([deviceSerial])
  @@index([status])
  @@index([deletedAt])
}

model TerminalConfiguration {
  id               String     @id @default(uuid())
  deviceId         String     @unique
  device           PosDevice  @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  receiptHeader    String?
  receiptFooter    String?
  currency         Currency   @default(USD)
  timezone         String     @default("UTC")
  language         String     @default("en")
  printerEnabled   Boolean    @default(true)
  autoPrint        Boolean    @default(true)

  gatewayId        String?
  gateway          GatewayProvider? @relation(fields: [gatewayId], references: [id], onDelete: SetNull)

  theme            String?

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model DeviceSession {
  id           String     @id @default(uuid())
  deviceId     String
  device       PosDevice  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  token        String     @unique
  issuedAt     DateTime   @default(now())
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([deviceId])
  @@index([token])
  @@index([expiresAt])
}

model DeviceCommand {
  id           String               @id @default(uuid())
  deviceId     String
  device       PosDevice            @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  command      DeviceCommandType
  status       DeviceCommandStatus  @default(PENDING)
  payload      Json?
  response     Json?
  error        String?
  sentAt       DateTime?
  executedAt   DateTime?
  expiresAt    DateTime?

  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([deviceId])
  @@index([status])
  @@index([command])
  @@index([createdAt(sort: Desc)])
}

model PaymentSession {
  id                 String                 @id @default(uuid())
  merchantId         String
  merchant           Merchant               @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deviceId           String
  device             PosDevice              @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  userId             String?
  user               User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)

  amount             Decimal                @db.Decimal(12, 2)
  currency           Currency               @default(USD)
  status             PaymentSessionStatus   @default(PENDING)
  gatewaySessionId   String?
  gatewayProviderId  String?
  gatewayProvider    GatewayProvider?       @relation(fields: [gatewayProviderId], references: [id], onDelete: SetNull)

  metadata           Json?

  transaction        Transaction?

  events             PaymentEvent[]

  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([merchantId])
  @@index([deviceId])
  @@index([userId])
  @@index([status])
  @@index([gatewaySessionId])
  @@index([createdAt(sort: Desc)])
}

model PaymentEvent {
  id           String              @id @default(uuid())
  sessionId    String
  session      PaymentSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  status       PaymentEventStatus  @default(CREATED)
  description  String?
  metadata     Json?

  createdAt    DateTime            @default(now())

  @@index([sessionId])
  @@index([createdAt(sort: Desc)])
}

model Transaction {
  id                       String                 @id @default(uuid())
  merchantId               String
  merchant                 Merchant               @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  deviceId                 String
  device                   PosDevice              @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  userId                   String?
  user                     User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)

  sessionId                String?                @unique
  session                  PaymentSession?        @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  amount                   Decimal                @db.Decimal(12, 2)
  currency                 Currency               @default(USD)
  status                   TransactionStatus      @default(PENDING)
  gatewayTransactionId     String?
  approvalCode             String?
  paymentMethod            String                 @default("CARD")

  settlementStatus         SettlementStatus       @default(PENDING)
  usdtAmount               Decimal?               @db.Decimal(20, 8)
  usdtTxid                 String?
  settlementProvider       String?

  metadata                 Json?

  receipt                  Receipt?
  gatewayTransaction       GatewayTransaction?
  settlement               SettlementRecord?
  events                   TransactionEvent[]

  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  @@index([merchantId])
  @@index([deviceId])
  @@index([userId])
  @@index([status])
  @@index([settlementStatus])
  @@index([gatewayTransactionId])
  @@index([sessionId])
  @@index([createdAt(sort: Desc)])
}

model TransactionEvent {
  id             String                 @id @default(uuid())
  transactionId  String
  transaction    Transaction            @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  status         TransactionEventStatus @default(CREATED)
  description    String?
  metadata       Json?

  createdAt      DateTime               @default(now())

  @@index([transactionId])
  @@index([createdAt(sort: Desc)])
}

model Receipt {
  id                 String       @id @default(uuid())
  transactionId      String       @unique
  transaction        Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  content            String
  printStatus        PrintStatus  @default(PENDING)
  printedAt          DateTime?
  printedByDeviceId  String?
  printRetryCount    Int          @default(0)

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([transactionId])
  @@index([printStatus])
}

model ReceiptTemplate {
  id               String     @id @default(uuid())
  merchantId       String
  merchant         Merchant   @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name             String
  content          String
  isDefault        Boolean    @default(false)

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([merchantId, name])
  @@index([merchantId])
}

model Wallet {
  id               String                      @id @default(uuid())
  merchantId       String
  merchant         Merchant                    @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  address          String
  chain            Blockchain                  @default(ERC20)
  currency         Currency                    @default(USDT)
  balance          Decimal                     @default(0) @db.Decimal(20, 8)
  lastSyncAt       DateTime?

  walletTxs        WalletTransaction[]

  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  @@unique([merchantId, address])
  @@index([merchantId])
  @@index([address])
}

model WalletTransaction {
  id                String                    @id @default(uuid())
  walletId          String
  wallet            Wallet                    @relation(fields: [walletId], references: [id], onDelete: Cascade)

  type              WalletTransactionType     @default(CREDIT)
  amount            Decimal                   @db.Decimal(20, 8)
  fee               Decimal                   @default(0) @db.Decimal(20, 8)
  txid              String?
  status            WalletTransactionStatus   @default(PENDING)
  confirmedAt       DateTime?
  transactionId     String?
  transaction       Transaction?              @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([walletId])
  @@index([transactionId])
  @@index([status])
  @@index([txid])
}

model SettlementRecord {
  id               String             @id @default(uuid())
  transactionId    String             @unique
  transaction      Transaction        @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  provider         String
  requestedAt      DateTime           @default(now())
  completedAt      DateTime?
  status           SettlementStatus   @default(PENDING)
  usdtAmount       Decimal            @db.Decimal(20, 8)
  usdtTxid         String?
  fee              Decimal            @default(0) @db.Decimal(20, 8)
  errorMessage     String?
  providerResponse Json?

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([transactionId])
  @@index([status])
  @@index([usdtTxid])
}

model GatewayProvider {
  id               String                 @id @default(uuid())
  name             GatewayProviderName    @unique
  isActive         Boolean                @default(true)
  displayName      String
  configSchema     Json?
  baseUrl          String?
  priority         Int                    @default(0)

  gatewayTxs       GatewayTransaction[]
  credentials      GatewayCredential[]
  paymentSessions  PaymentSession[]
  terminalConfigs  TerminalConfiguration[]
  merchantSettings MerchantSettings[]

  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  @@index([isActive])
  @@index([priority])
}

model GatewayCredential {
  id               String                   @id @default(uuid())
  merchantId       String
  merchant         Merchant                 @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  providerId       String
  provider         GatewayProvider          @relation(fields: [providerId], references: [id], onDelete: Cascade)

  apiKey           String?
  secretKey        String?
  webhookSecret    String?
  environment      String                   @default("sandbox")
  status           GatewayCredentialStatus  @default(ACTIVE)
  extraConfig      Json?

  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([merchantId, providerId])
  @@index([merchantId])
  @@index([providerId])
  @@index([status])
}

model GatewayTransaction {
  id                   String                    @id @default(uuid())
  merchantId           String
  merchant             Merchant                  @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  gatewayProviderId    String
  gatewayProvider      GatewayProvider           @relation(fields: [gatewayProviderId], references: [id], onDelete: Cascade)

  transactionId        String?                   @unique
  transaction          Transaction?              @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  gatewayReferenceId   String?
  request              Json
  response             Json?
  status               GatewayTransactionStatus  @default(PENDING)
  errorMessage         String?

  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  @@index([merchantId])
  @@index([gatewayProviderId])
  @@index([transactionId])
  @@index([gatewayReferenceId])
  @@index([status])
}

model ExchangeRate {
  id           String     @id @default(uuid())
  merchantId   String?
  merchant     Merchant?  @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  fromCurrency Currency
  toCurrency   Currency
  rate         Decimal    @db.Decimal(20, 8)
  provider     String
  timestamp    DateTime   @default(now())

  createdAt    DateTime   @default(now())

  @@index([merchantId])
  @@index([fromCurrency, toCurrency])
  @@index([timestamp(sort: Desc)])
}

model WebhookLog {
  id             String   @id @default(uuid())
  merchantId     String?
  merchant       Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  headers        Json?
  payload        Json?
  rawBody        String?
  signature      String?

  status         Int
  response       String?
  processingTime Int?
  receivedAt     DateTime @default(now())

  transactionId  String?
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  sessionId      String?
  session        PaymentSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  createdAt      DateTime @default(now())

  @@index([merchantId])
  @@index([transactionId])
  @@index([sessionId])
  @@index([receivedAt(sort: Desc)])
}

model Report {
  id             String       @id @default(uuid())
  merchantId     String
  merchant       Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  type           ReportType   @default(DAILY)
  generatedAt    DateTime     @default(now())
  data           Json
  fileUrl        String?
  periodStart    DateTime?
  periodEnd      DateTime?

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([merchantId])
  @@index([generatedAt(sort: Desc)])
  @@index([type])
}

model Notification {
  id           String           @id @default(uuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchantId   String?
  merchant     Merchant?        @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  type         NotificationType @default(IN_APP)
  title        String
  message      String
  readAt       DateTime?
  data         Json?

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([userId])
  @@index([merchantId])
  @@index([readAt])
  @@index([createdAt(sort: Desc)])
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  merchantId   String?
  merchant     Merchant? @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  action       String
  details      Json?
  ipAddress    String?
  userAgent    String?

  createdAt    DateTime @default(now()) // immutable

  @@index([userId])
  @@index([merchantId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
}

model ApiKey {
  id           String         @id @default(uuid())
  merchantId   String
  merchant     Merchant       @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  name         String
  keyHash      String         @unique
  status       ApiKeyStatus   @default(ACTIVE)
  expiresAt    DateTime?
  lastUsedAt   DateTime?
  permissions  Json?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([merchantId])
  @@index([keyHash])
  @@index([status])
}

model SoftwareUpdate {
  id               String               @id @default(uuid())
  version          String               @unique
  releaseNotes     String?
  fileUrl          String
  checksum         String?
  isMandatory      Boolean              @default(false)
  minAppVersion    String?
  status           SoftwareUpdateStatus @default(DRAFT)
  releasedAt       DateTime?

  deviceUpdates    DeviceUpdate[]

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([version])
  @@index([status])
  @@index([releasedAt])
}

model DeviceUpdate {
  id               String        @id @default(uuid())
  deviceId         String
  device           PosDevice     @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  updateId         String
  update           SoftwareUpdate @relation(fields: [updateId], references: [id], onDelete: Cascade)

  status           DeviceUpdateStatus @default(PENDING)
  startedAt        DateTime?
  completedAt      DateTime?
  errorMessage     String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([deviceId, updateId])
  @@index([deviceId])
  @@index([updateId])
  @@index([status])
}

model TerminalLog {
  id           String      @id @default(uuid())
  deviceId     String
  device       PosDevice   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  level        LogLevel    @default(INFO)
  message      String
  stackTrace   String?
  metadata     Json?

  createdAt    DateTime    @default(now()) // immutable

  @@index([deviceId])
  @@index([createdAt(sort: Desc)])
  @@index([level])
}
