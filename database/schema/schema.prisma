generator client {
  provider = "prisma-client-js"
  output   = "../../backend/node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/////////////////////////////////////////////////
// ENUMS
/////////////////////////////////////////////////

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CASHIER
}

enum StoreStatus {
  ACTIVE
  INACTIVE
}

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum InventoryMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  RETURN
}

enum PurchaseStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_MONEY
  OTHER
}

/////////////////////////////////////////////////
// USERS
/////////////////////////////////////////////////

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String
  role         UserRole  @default(CASHIER)

  merchantId   String
  merchant     Merchant  @relation(fields: [merchantId], references: [id])

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

/////////////////////////////////////////////////
// MERCHANTS
/////////////////////////////////////////////////

model Merchant {
  id            String      @id @default(cuid())
  businessName  String
  email         String      @unique
  phone         String?
  address       String?

  users         User[]
  stores        Store[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

/////////////////////////////////////////////////
// STORES
/////////////////////////////////////////////////

model Store {
  id            String       @id @default(cuid())

  name          String
  phone         String?
  address       String?

  status        StoreStatus  @default(ACTIVE)

  merchantId    String
  merchant      Merchant     @relation(fields: [merchantId], references: [id])

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}
